# PostgreSQL connection
DATABASE_URL=postgresql://gst_genie:gst_genie_pass@localhost:5432/gst_genie

# JWT
JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS
FRONTEND_ORIGIN=http://localhost:3000

# Google OAuth (leave blank until you have real credentials — Google
# Sign-In will 501 until these are set)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stubbed integrations, not required for auth to work ---
# OCR_PROVIDER_API_KEY=
# WHATSAPP_BUSINESS_TOKEN=
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASSWORD=
